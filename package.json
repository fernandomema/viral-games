{
	"name": "viral-games",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"dev:server": "tsx watch --env-file=.env server/index.ts",
		"dev:all": "npm run dev:server & npm run dev",
		"build": "vite build",
		"postbuild": "npx svelte-sitemap",
		"start": "tsx server/index.ts",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@iconify-json/material-symbols": "^1.2.65",
		"@iconify/tailwind4": "^1.2.3",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.1.18",
		"@types/express": "^5.0.6",
		"@types/ws": "^8.18.1",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"svelte-sitemap": "^3.1.0",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vite-plugin-devtools-json": "^1.0.0"
	},
	"dependencies": {
		"@discord/embedded-app-sdk": "^2.4.1",
		"express": "^5.2.1",
		"tsx": "^4.21.0",
		"web-haptics": "^0.0.6",
		"ws": "^8.20.0"
	}
}
